# ============================================================
# Knowledge-Base-Copilot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
APP_NAME=Knowledge-Base-Copilot
DEBUG=false
LOG_LEVEL=INFO

# NVIDIA NIM (LLM)
NIM_BASE_URL=https://integrate.api.nvidia.com
NIM_API_KEY=your_nvidia_api_key_here
NIM_MODEL_NAME=meta/llama3-70b-instruct
NIM_MAX_TOKENS=1024
NIM_TEMPERATURE=0.2

# NeMo Retriever (Embeddings)
NEMO_RETRIEVER_URL=http://nemo-retriever:8080
NEMO_RETRIEVER_MODEL=nvidia/nv-embedqa-e5-v5
NEMO_EMBEDDING_DIMENSION=1024

# Vector DB (choose: milvus or pinecone)
VECTOR_DB_PROVIDER=pinecone

# Milvus (if VECTOR_DB_PROVIDER=milvus)
MILVUS_URI=http://milvus:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=kb_documents

# Pinecone (if VECTOR_DB_PROVIDER=pinecone)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=kb-copilot
PINECONE_HOST=https://your-index-host.pinecone.io

VECTOR_TOP_K=5

# Okta OIDC
OKTA_ISSUER=https://your-org.okta.com/oauth2/default
OKTA_AUDIENCE=api://kb-copilot
OKTA_NAMESPACE_CLAIM=groups
OKTA_GROUP_NAMESPACE_MAP_JSON={"Engineering":"eng","Finance":"finance"}
OKTA_JWKS_CACHE_TTL=3600

# PostgreSQL
DATABASE_URL=postgresql://kb_user:kb_pass@postgres:5432/kb_copilot
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# Presidio PII Detection
PRESIDIO_ENABLED=true
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:5000/analyze
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:5001/anonymize
PRESIDIO_SCORE_THRESHOLD=0.5

# HITL Escalation
HITL_CONFIDENCE_THRESHOLD=0.65
HITL_SENSITIVE_TOPICS=["salary","legal","medical","confidential"]

# Redis (Rate Limiting)
REDIS_URL=redis://redis:6379
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# Audit
AUDIT_TABLE_NAME=audit_logs
